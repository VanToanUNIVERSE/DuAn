<tr><th>STT</th><th>Thuộc tính</th><th>Kiểu dữ liệu</th><th>Ràng buộc</th><th>Diễn giải</th></tr>
<tr><td>1</td><td>id</td><td>bigint(20) unsigned</td><td>PK</td><td>Khóa chính</td></tr>
<tr><td>2</td><td>user_id</td><td>bigint(20) unsigned</td><td>Not null</td><td>Khóa ngoại tham chiếu bảng người dùng</td></tr>
<tr><td>3</td><td>type</td><td>varchar(255)</td><td>Not null</td><td></td></tr>
<tr><td>4</td><td>message</td><td>text</td><td>Not null</td><td></td></tr>
<tr><td>5</td><td>is_read</td><td>tinyint(1)</td><td>Not null, Default 0</td><td>Trạng thái read</td></tr>
<tr><td>6</td><td>created_at</td><td>timestamp</td><td>Nullable, Default NULL</td><td>Thời gian tạo</td></tr>
<tr><td>7</td><td>updated_at</td><td>timestamp</td><td>Nullable, Default NULL</td><td>Thời gian cập nhật</td></tr>
</table>
</body></html>